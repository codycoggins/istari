# Docker
docker-compose.override.yml

# Alembic
backend/migrations/versions/*.pyc

# Secrets / credentials — catch-all for key/cert files anywhere in the tree
*.pem
*.key

# Secrets directory — all contents ignored except the placeholder
# credentials.json, *_token.json etc. must all live here, not in project root
secrets/*
!secrets/.gitkeep

# Personal memory files (user-owned, not checked in by default)
memory/USER.md
memory/goals.md
/icons/

# Log files (volume-mounted from Docker containers)
logs/*.log
logs/*.log.*
.claude/worktrees/
