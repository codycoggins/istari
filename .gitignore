*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
frontend/dist/
frontend/build/
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# Test / Coverage
.coverage
htmlcov/
